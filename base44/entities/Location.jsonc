{
  "name": "Location",
  "type": "object",
  "properties": {
    "org_id": {
      "type": "string",
      "description": "Organization ID"
    },
    "name": {
      "type": "string",
      "description": "Location name"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "pinned": {
      "type": "boolean",
      "default": false,
      "description": "Pinned locations always appear at the top"
    }
  },
  "required": [
    "org_id",
    "name"
  ]
}